msgstr ""

#. welcome.wordBuilder.goal
msgctxt "welcome.wordBuilder.goal"
msgid "Develop literacy skills through playful, visual letter support."
msgstr ""

#. welcome.wordBuilder.how
msgctxt "welcome.wordBuilder.how"
msgid "See a picture, hear the word, drag letters in the right order to spell it."
msgstr ""

#. welcome.wordBuilder.purpose
msgctxt "welcome.wordBuilder.purpose"
msgid "Build words letter by letter with visual support."
msgstr ""

#. welcome.wordParade.goal
msgctxt "welcome.wordParade.goal"
msgid "Improve the ability to hear and produce sound differences between similar words."
msgstr ""

#. welcome.wordParade.how
msgctxt "welcome.wordParade.how"
msgid "Listen to word pairs, practice saying them, and guess which word is playing."
msgstr ""

#. welcome.wordParade.purpose
msgctxt "welcome.wordParade.purpose"
msgid "Minimal pair training — words that differ by just one sound. Critical for phonological awareness."
msgstr ""

