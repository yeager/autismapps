msgctxt "takk.sign.jag"
msgid "Point to yourself with index finger"
msgstr "Peka på dig själv med pekfingret"

#. takk.sign.katt
msgctxt "takk.sign.katt"
msgid "Pinch and pull whiskers from cheeks"
msgstr "Nyp och dra i morrhåren från kinderna"

#. takk.sign.kompis
msgctxt "takk.sign.kompis"
msgid "Hook index fingers together"
msgstr "Haka fast pekfingrarna i varandra"

#. takk.sign.lasa
msgctxt "takk.sign.lasa"
msgid "Flat hands open like a book"
msgstr "Platta händer öppna som en bok"

#. takk.sign.ledsen
msgctxt "takk.sign.ledsen"
msgid "Finger traces tear down cheek"
msgstr "Fingrarna drar ner tårar längs kinden"

