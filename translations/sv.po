msgstr "Knyt näven på öppen handflata, lyft uppåt"

#. takk.sign.hund
msgctxt "takk.sign.hund"
msgid "Pat thigh twice (calling a dog)"
msgstr "Klappa låret två gånger (kalla på en hund)"

