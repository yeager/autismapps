#. takk.description
msgctxt "takk.description"
msgid ""
"Signs as Alternative and Augmentative Communication (TAKK) — sign the key "
"words while speaking"
msgstr ""
"Tecken som alternativ och kompletterande kommunikation (TAKK) — teckna "
"nyckelorden medan du talar"

#. takk.how_to_sign
msgctxt "takk.how_to_sign"
msgid "How to sign"
msgstr "Hur man skriver under"

#. takk.see_video
msgctxt "takk.see_video"
msgid "See sign video"
msgstr "Se skyltvideo"

#. takk.sign.arg
msgctxt "takk.sign.arg"
msgid "Claw hand in front of face, tense expression"
msgstr "Klohand framför ansiktet, spänd min"

#. takk.sign.ata
msgctxt "takk.sign.ata"
msgid "Pinch fingers to thumb, move to mouth"
msgstr "Nyp fingrarna mot tummen, förflytta till munnen"

#. takk.sign.dricka
msgctxt "takk.sign.dricka"
msgid "C-hand shape, tip to mouth (like drinking)"
msgstr "C-handform, spetsen mot munnen (som när man dricker)"

#. takk.sign.du
msgctxt "takk.sign.du"
msgid "Point forward with index finger"
msgstr "Peka framåt med pekfingret"

#. takk.sign.ga
msgctxt "takk.sign.ga"
msgid "Two fingers 'walk' on other palm"
msgstr "Två fingrar \"går\" på den andra handflatan"

#. takk.sign.glad
msgctxt "takk.sign.glad"
msgid "Hands circle upward on chest (happy feeling)"
msgstr "Händerna cirklar uppåt på bröstet (glad känsla)"

#. takk.sign.hem
msgctxt "takk.sign.hem"
msgid "Fingertips together forming roof shape"
msgstr "Fingertopparna ihop så att de bildar ett tak"

#. takk.sign.hjalp
msgctxt "takk.sign.hjalp"
msgid "Fist on open palm, lift upward"
msgstr "Knyt näven på öppen handflata, lyft uppåt"

#. takk.sign.hund
msgctxt "takk.sign.hund"
msgid "Pat thigh twice (calling a dog)"
msgstr "Klappa låret två gånger (kalla på en hund)"

#. takk.sign.inte
msgctxt "takk.sign.inte"
msgid "Flat hand, sweep sideways away from body"
msgstr "Platt hand, svep sidledes bort från kroppen"

#. takk.sign.ja
msgctxt "takk.sign.ja"
msgid "Nod fist up and down (like knocking)"
msgstr "Nicka med näven upp och ner (som om du knackar)"

#. takk.sign.jag
msgctxt "takk.sign.jag"
msgid "Point to yourself with index finger"
msgstr "Peka på dig själv med pekfingret"

#. takk.sign.katt
msgctxt "takk.sign.katt"
msgid "Pinch and pull whiskers from cheeks"
msgstr "Nyp och dra i morrhåren från kinderna"

#. takk.sign.kompis
msgctxt "takk.sign.kompis"
msgid "Hook index fingers together"
msgstr "Haka fast pekfingrarna i varandra"

#. takk.sign.lasa
msgctxt "takk.sign.lasa"
msgid "Flat hands open like a book"
msgstr "Platta händer öppna som en bok"

#. takk.sign.ledsen
msgctxt "takk.sign.ledsen"
msgid "Finger traces tear down cheek"
msgstr "Fingrarna drar ner tårar längs kinden"

#. takk.sign.leka
msgctxt "takk.sign.leka"
msgid "Y-hands (thumbs and pinkies out), shake"
msgstr "Y-händer (tummar och lillfingrar ut), skaka"

#. takk.sign.mamma
msgctxt "takk.sign.mamma"
msgid "Tap chin with thumb (from M-hand)"
msgstr "Knacka hakan med tummen (från M-handen)"

#. takk.sign.mat
msgctxt "takk.sign.mat"
msgid "Pinch to mouth (like eating)"
msgstr "Nyp till munnen (som när man äter)"

#. takk.sign.mer
msgctxt "takk.sign.mer"
msgid "Pinch fingers together, tap twice"
msgstr "Nyp ihop fingrarna, tryck två gånger"

#. takk.sign.nej
msgctxt "takk.sign.nej"
msgid "Shake flat hand side to side"
msgstr "Skaka med handen platt från sida till sida"

#. takk.sign.pappa
msgctxt "takk.sign.pappa"
msgid "Tap forehead with thumb (from P-hand)"
msgstr "Knacka pannan med tummen (från P-handen)"

#. takk.sign.radd
msgctxt "takk.sign.radd"
msgid "Fists shake near chest (trembling)"
msgstr "Knäppar händerna nära bröstet (skakar)"

#. takk.sign.skola
msgctxt "takk.sign.skola"
msgid "Clap hands twice (like getting attention)"
msgstr "Klappa händerna två gånger (som för att få uppmärksamhet)"

#. takk.sign.slut
msgctxt "takk.sign.slut"
msgid "Both hands open, push away from body"
msgstr "Båda händerna öppna, tryck bort från kroppen"

#. takk.sign.sova
msgctxt "takk.sign.sova"
msgid "Palm against cheek, tilt head"
msgstr "Handflatan mot kinden, luta huvudet"

#. takk.sign.titta
msgctxt "takk.sign.titta"
msgid "V-fingers point from eyes outward"
msgstr "V-fingrarna pekar utåt från ögonen"

#. takk.sign.toalett
msgctxt "takk.sign.toalett"
msgid "T-hand shape, shake slightly"
msgstr "T-handform, skaka lätt"

#. takk.sign.trott
msgctxt "takk.sign.trott"
msgid "Both hands on chest, drop downward"
msgstr "Båda händerna på bröstet, falla nedåt"

#. takk.sign.vad
msgctxt "takk.sign.vad"
msgid "Palms up, shake hands slightly"
msgstr "Handflatorna uppåt, skaka handen lätt"

#. takk.sign.var
msgctxt "takk.sign.var"
msgid "Palms up, shrug shoulders"
msgstr "Handflatorna uppåt, ryck på axlarna"

#. takk.sign.vatten
msgctxt "takk.sign.vatten"
msgid "W-hand shape at chin"
msgstr "W-handform vid hakan"

#. takk.sign.vill
msgctxt "takk.sign.vill"
msgid "Point forward with index finger, pull toward chest"
msgstr "Peka framåt med pekfingret, dra mot bröstet"

#. takk.title
msgctxt "takk.title"
msgid "TAKK Signs"
msgstr "TAKK-skyltar"

